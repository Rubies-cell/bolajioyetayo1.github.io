  .container { max-width: 900px; margin: 0 auto; padding: 0 2rem; }
  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.2rem;
    display: flex; align-items: center; gap: 0.8rem;
  }
  .section-label::after {
