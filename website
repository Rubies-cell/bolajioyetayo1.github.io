  .profile-photo {
    position: relative;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top center;
    border: 4px solid var(--bg);
    display: block;
    z-index: 1;
  }
  .about-bio p { max-width: 560px; }
  .about-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 1.5rem 0; }
  .tag {
    font-size: 0.75rem;
    font-family: 'DM Mono', monospace;
    padding: 3px 10px;
    border-radius: 2px;
    background: var(--surface2);
    color: var(--accent2);
    border: 1px solid rgba(91,155,213,0.2);
  }
