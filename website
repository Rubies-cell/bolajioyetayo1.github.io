  .about-links a:hover { color: var(--accent); }
  .about-links a::before { content: '→'; color: var(--accent); font-size: 0.8rem; }
  .stat-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.8rem;
    display: flex; flex-direction: column; gap: 1.4rem;
  }
  .stat-item {}
  .stat-number {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: var(--accent);
    line-height: 1;
  }
  .stat-desc {
    font-size: 0.78rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-top: 0.2rem;
  }
  .stat-divider { height: 1px; background: var(--border); }

  /* ── RESEARCH CARDS ── */
  #research { background: var(--surface); }
  .research-intro { max-width: 620px; margin-bottom: 3rem; }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.2rem;
  }
  .card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
    display: block;
    cursor: default;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(200,169,110,0.35);
    box-shadow: 0 12px 40px rgba(0,0,0,0.4);
