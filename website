  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 4rem;
    align-items: start;
  }
  .photo-block {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .profile-photo-wrap {
    position: relative;
    width: 200px;
    margin: 0 auto;
  }
  .profile-photo-wrap::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, var(--accent), var(--accent2), var(--accent));
