  /* card gradient thumbs */
  .thumb-epi { background: linear-gradient(135deg, #1a2744 0%, #0f3460 50%, #1a2744 100%); }
  .thumb-glia { background: linear-gradient(135deg, #1f3a1f 0%, #0d4a2e 50%, #1f3a1f 100%); }
