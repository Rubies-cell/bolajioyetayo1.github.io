    margin-right: auto;
    letter-spacing: 0.02em;
  }
  nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s;
    padding: 4px 0;
    border-bottom: 1px solid transparent;
  }
  nav a:hover, nav a.active {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  /* ── SECTIONS ── */
